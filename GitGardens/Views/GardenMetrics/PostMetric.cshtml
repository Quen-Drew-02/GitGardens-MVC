@model GitGardens.Models.AddGardenMetric

@{
    ViewData["Title"] = "Add Metrics";
}

<div class="container mt-5">
    <h2 class="page-title text-center mb-4">Add Garden Metrics</h2>
    <div class="card shadow-sm p-4 mx-auto" style="max-width: 800px;">

        <form asp-action="PostMetric" method="post" class="mt-2">

            <input type="hidden" asp-for="GardenID" />

            <!-- Moisture -->
            <div class="form-group mb-4">
                <label class="form-label fw-bold">Moisture: <span id="moistureVal" class="text-primary">@Model.Moisture</span>%</label>
                <input type="range" asp-for="Moisture" min="0" max="100" class="form-range"
                       value="@Model.Moisture"
                       oninput="document.getElementById('moistureVal').innerText = this.value" />
            </div>

            <!-- PH -->
            <div class="form-group mb-4">
                <label class="form-label fw-bold">pH: <span id="phVal" class="text-primary">@Model.PH</span></label>
                <input type="range" asp-for="PH" min="0" max="14" step="0.1" class="form-range"
                       value="@Model.PH"
                       oninput="document.getElementById('phVal').innerText = this.value" />
            </div>

            <!-- Temperature -->
            <div class="form-group mb-4">
                <label class="form-label fw-bold">Temperature: <span id="tempVal" class="text-primary">@Model.Temperature</span>°C</label>
                <input type="range" asp-for="Temperature" min="-15" max="50" class="form-range"
                       value="@Model.Temperature"
                       oninput="document.getElementById('tempVal').innerText = this.value" />
            </div>

            <!-- Humidity -->
            <div class="form-group mb-4">
                <label class="form-label fw-bold">Humidity: <span id="humVal" class="text-primary">@Model.Humidity</span>%</label>
                <input type="range" asp-for="Humidity" min="0" max="100" class="form-range"
                       value="@Model.Humidity"
                       oninput="document.getElementById('humVal').innerText = this.value" />
            </div>

            <!-- Sunlight -->
            <div class="form-group mb-4">
                <label class="form-label fw-bold">Sunlight: <span id="sunVal" class="text-primary">@Model.Sunlight</span>%</label>
                <input type="range" asp-for="Sunlight" min="0" max="100" class="form-range"
                       value="@Model.Sunlight"
                       oninput="document.getElementById('sunVal').innerText = this.value" />
            </div>

            <!-- Nitrogen -->
            <div class="form-group mb-4">
                <label class="form-label fw-bold">Nitrogen: <span id="nitVal" class="text-primary">@Model.Nitrogen</span>%</label>
                <input type="range" asp-for="Nitrogen" min="0" max="100" class="form-range"
                       value="@Model.Nitrogen"
                       oninput="document.getElementById('nitVal').innerText = this.value" />
            </div>

            <hr />

            <!-- Actions -->
            <div class="d-flex justify-content-between align-items-center mt-4">
                <a class="btn btn-outline-secondary px-4" asp-action="GardenList" asp-controller="Garden">
                    <i class="bi bi-x-circle"></i> Cancel
                </a>
                <button type="submit" class="btn btn-success px-5 shadow-sm">
                    <i class="bi bi-check-circle"></i> Save Metrics
                </button>
            </div>

        </form>

    </div>
</div>

