@model GitGardens.Models.AddGardenMetric

@{
    ViewData["Title"] = "Add Metrics";
}

<div class="container mt-5">
    <h2 class="page-title">Add Garden Metrics</h2>
    <div class="card shadow-sm p-4">

        <form asp-action="PostMetric" method="post" class="mt-4">

            <input type="hidden" asp-for="GardenID" />

            <!-- Moisture -->
            <div class="form-group mb-3">
            <label class="metric-label">Moisture: <span id="moistureVal">@Model.Moisture</span>%</label>
            <input type="range" asp-for="Moisture" min="0" max="100" class="form-range"
                   oninput="moistureVal.innerText = this.value" />
            </div>

            <!-- PH -->
            <div class="form-group mb-3">
            <label class="metric-label">pH: <span id="phVal">@Model.PH</span></label>
            <input type="range" asp-for="PH" min="0" max="14" step="0.1" class="form-range"
                   oninput="phVal.innerText = this.value" />
            </div>

            <!-- Temperature -->
            <div class="form-group mb-3">
            <label class="metric-label">Temperature: <span id="tempVal">@Model.Temperature</span>°C</label>
            <input type="range" asp-for="Temperature" min="-15" max="50" class="form-range"
                   oninput="tempVal.innerText = this.value" />
            </div>

            <!-- Humidity -->
            <div class="form-group mb-3">
            <label class="metric-label">Humidity: <span id="humVal">@Model.Humidity</span>%</label>
            <input type="range" asp-for="Humidity" min="0" max="100" class="form-range"
                   oninput="humVal.innerText = this.value" />
            </div>

            <!-- Sunlight -->
            <div class="form-group mb-3">
            <label class="metric-label">Sunlight: <span id="sunVal">@Model.Sunlight</span>%</label>
            <input type="range" asp-for="Sunlight" min="0" max="100" class="form-range"
                   oninput="sunVal.innerText = this.value" />
            </div>

            <!-- Nitrogen -->
            <div class="form-group mb-3">
            <label class="metric-label">Nitrogen: <span id="nitVal">@Model.Nitrogen</span>%</label>
            <input type="range" asp-for="Nitrogen" min="0" max="100" class="form-range"
                   oninput="nitVal.innerText = this.value" />
            </div>

            <!-- Post Metrics -->
            <div class="d-flex justify-content-between">
                <button type="submit" class="btn btn-primary">Save Metrics</button>
                <a class="btn btn-danger" asp-action="GardenList" asp-controller="Garden">Cancel</a>
            </div>

        </form>

    </div>
</div>

