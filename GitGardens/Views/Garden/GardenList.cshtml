@model List<GitGardens.Models.GardenList>

@{
    ViewData["Title"] = "My Gardens";
}

<div class="container mt-5">
    <h2 class="text-center">My Gardens</h2>
        <div class="card shadow-sm p-4">

    <div class="row">

        @if (!Model.Any())
        {
            <div class="col-12">
                <div class="alert alert-info">
                    You have no gardens Yet + Create one to get Going
                </div>
            </div>
        }
        else
        {
            @foreach (var garden in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card p-3 h-100">

                        <h5 class="card-title">@garden.GardenName</h5>

                        <p class="body-text">
                            @(string.IsNullOrEmpty(garden.Description)
                                ? "No Description Provided"
                                : garden.Description)
                        </p>

                        <small class="text-muted">
                            Created: @garden.CreatedAt.ToShortDateString()
                        </small>

                        <div class="mt-3">

                            <!-- Edit Garden -->
                            <a class="btn btn-warning btn-sm me-2"
                                   asp-controller="Garden"
                                   asp-action="EditGarden"
                                   asp-route-id="@garden.GardenID">
                                   Edit
                            </a>

                            <!-- Metrics -->
                            <a class="btn btn-primary btn-sm"
                                   asp-controller="GardenMetrics"
                                   asp-action="PostMetric"
                                   asp-route-gardenId="@garden.GardenID">
                                   Metrics
                            </a>

                            <!-- Tips based on Metrics -->
                            <a class="btn btn-info btn-sm"
                                   asp-controller="GardenTips"
                                   asp-action="ViewTips"
                                   asp-route-gardenId="@garden.GardenID">
                                   Tips
                            </a>

                        </div>

                    </div>
                </div>
            }
            }
        </div>
    </div>
</div>

