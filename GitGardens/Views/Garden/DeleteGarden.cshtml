@model GitGardens.Models.DeleteGarden

@{
    ViewData["Title"] = "Delete Garden";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow">
                <div class="card-header bg-danger text-white">
                    <h3 class="card-title mb-0">Confirm Deletion</h3>
                </div>
                <div class="card-body">
                    <p class="lead">Are you sure you want to delete this garden? This action cannot be undone.</p>
                    
                    <hr />
                    
                    <dl class="row">
                        <dt class="col-sm-4">Garden Name:</dt>
                        <dd class="col-sm-8"><strong>@Model.GardenName</strong></dd>

                        <dt class="col-sm-4">Description:</dt>
                        <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.Description) ? "No description provided." : Model.Description)</dd>
                    </dl>

                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        Warning: Deleting this garden will also remove all associated crop metrics and data.
                    </div>

                    <form asp-action="DeleteGarden" asp-controller="Garden" method="post">
                        <input type="hidden" asp-for="GardenId" />

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="GardenList" asp-controller="Garden" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Back to List
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Permanently Delete
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>