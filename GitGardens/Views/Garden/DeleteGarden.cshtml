@model GitGardens.Models.DeleteGarden

@{
    ViewData["Title"] = "Delete Garden";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card border-danger shadow-lg">
                <div class="card-header bg-danger text-white py-3">
                    <h3 class="card-title mb-0">Confirm Deletion</h3>
                </div>
                <div class="card-body p-4">
                    <p class="lead text-danger"><strong>Warning:</strong> You are about to permanently delete this garden.</p>
                    
                    <hr />
                    
                    <div class="mb-3">
                        <label class="text-muted d-block small uppercase">Garden Name</label>
                        <p class="fs-4 fw-bold">@Model.GardenName</p>
                    </div>
                    <div class="mb-3">
                        <label class="text-muted d-block small uppercase">Description</label>
                        <p class="fs-5">@(string.IsNullOrEmpty(Model.Description) ? "N/A" : Model.Description)</p>
                    </div>

                    <div class="alert alert-light border-warning mt-4">
                        <i class="bi bi-exclamation-triangle-fill text-warning"></i>
                        All associated crop data and metrics will be lost.
                    </div>

                    <form asp-action="DeleteGarden" asp-controller="Garden" method="post">
                        <input type="hidden" asp-for="GardenId" />

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="GardenList" asp-controller="Garden" class="btn btn-secondary px-4">
                                Cancel
                            </a>
                            <button type="submit" class="btn btn-danger px-4">
                                Delete Permanently
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>