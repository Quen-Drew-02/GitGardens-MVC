@model GitGardens.Models.User

@{
    ViewData["Title"] = "User Profile";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2 class="mb-4 text-center">My Garden Profile</h2>
            
            <div class="card shadow border-0">
                <div class="card-header text-white text-center py-3" style="background-color: #2E8B57;">
                    <h5 class="mb-0">Profile Information</h5>
                </div>
                <div class="card-body p-4">
                    <!-- User Details -->
                    <div class="mb-3">
                        <label class="text-muted small fw-bold text-uppercase">Full Name</label>
                        <p class="fs-5 border-bottom pb-2">@Model.FullName</p>
                    </div>

                    <div class="mb-3">
                        <label class="text-muted small fw-bold text-uppercase">Email Address</label>
                        <p class="fs-5 border-bottom pb-2">@Model.Email</p>
                    </div>

                    <div class="mb-4">
                        <label class="text-muted small fw-bold text-uppercase">Assigned Role</label>
                        <div>
                            @if (Model.Role?.RoleName == "Admin")
                            {
                                <span class="badge bg-danger fs-6 px-3">Administrator</span>
                            }
                            else
                            {
                                <span class="badge bg-success fs-6 px-3">Gardener (User)</span>
                            }
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="d-grid gap-2 d-md-flex justify-content-md-between mt-4">
                        <a asp-action="EditProfile"
                               class="btn btn-outline-primary px-4">
                            <i class="bi bi-pencil-square"></i> Edit Details
                        </a>
                        
                        <a asp-action="DeleteProfile"
                               class="btn btn-outline-danger px-4">
                            <i class="bi bi-trash"></i> Delete Profile
                        </a>
                    </div>
                </div>
                <div class="card-footer bg-light text-center small text-muted">
                    Member since @DateTime.Now.Year
                </div>
            </div>

            <div class="text-center mt-3">
                <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-secondary">
                    &larr; Back to Dashboard
                </a>
            </div>
        </div>
    </div>
</div>